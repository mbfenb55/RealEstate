generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres.msummyxjiwusxuhjryqk:Terramony2024@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"
}

model User {
  id          String    @id @default(uuid()) @db.Uuid
  email       String    @unique
  fullName    String?   @map("full_name")
  companyName String?   @map("company_name")
  phone       String?
  logoUrl     String?   @map("logo_url")
  brandColor  String?   @default("#1E3A8A") @map("brand_color")
  credits     Int       @default(1)
  createdAt   DateTime  @default(now()) @map("created_at")
  invoices    Invoice[]
  payments    Payment[]
  shoots      Shoot[]

  @@map("users")
}

model Shoot {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @map("user_id") @db.Uuid
  status        ShootStatus @default(PROCESSING)
  type          ShootType
  adaNo         String      @map("ada_no")
  parselNo      String      @map("parsel_no")
  il            String
  ilce          String
  latitude      Float?
  longitude     Float?
  voiceoverText String?     @map("voiceover_text")
  audioUrl      String?     @map("audio_url")
  videoUrl      String?     @map("video_url")
  logoUrl       String?     @map("logo_url")
  phoneNumber   String?     @map("phone_number")
  brandColor    String?     @map("brand_color")
  nearbyLabels  Json?       @map("nearby_labels")
  landAnalysis  Json?       @map("land_analysis")
  viewCount     Int         @default(0) @map("view_count")
  publicToken   String?     @unique @default(uuid()) @map("public_token") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at")
  completedAt   DateTime?   @map("completed_at")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("shoots")
}

model Payment {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  amount       Float
  creditsAdded Int           @map("credits_added")
  status       PaymentStatus @default(PENDING)
  iyzicoToken  String?       @map("iyzico_token")
  createdAt    DateTime      @default(now()) @map("created_at")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("payments")
}

model Invoice {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  paymentId String   @map("payment_id") @db.Uuid
  pdfUrl    String?  @map("pdf_url")
  amount    Float
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([paymentId])
  @@map("invoices")
}

enum ShootStatus {
  PROCESSING
  READY
  FAILED
}

enum ShootType {
  DRONE
  TOUR_3D
  COMBO
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}
